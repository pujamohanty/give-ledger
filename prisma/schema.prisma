generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

enum Role {
  DONOR
  NGO
  ADMIN
}

enum ProjectStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  COMPLETED
  REJECTED
}

enum MilestoneStatus {
  PENDING
  UNDER_REVIEW
  COMPLETED
  REJECTED
}

enum DisbursementStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
}

enum NgoStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum PaymentMethod {
  CARD
  CRYPTO
  UPI
  BANK_TRANSFER
}

enum ProjectCategory {
  INCOME_GENERATION
  CHILD_CARE
  ELDERLY_CARE
  PHYSICALLY_DISABLED
  PET_CARE
  OTHER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          Role      @default(DONOR)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  ngo           Ngo?
  donations     Donation[]
  ratings       Rating[]
}

model Ngo {
  id           String    @id @default(cuid())
  userId       String    @unique
  orgName      String
  regNumber    String?
  country      String?
  website      String?
  description  String?   @db.Text
  logoUrl      String?
  trustScore   Float     @default(0)
  status       NgoStatus @default(PENDING)
  approvedAt   DateTime?
  rejectReason String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects     Project[]
  expenses     Expense[]
  ratings      Rating[]
}

model Project {
  id           String          @id @default(cuid())
  ngoId        String
  title        String
  description  String          @db.Text
  category     ProjectCategory
  coverImage   String?
  goalAmount   Float
  raisedAmount Float           @default(0)
  currency     String          @default("USD")
  status       ProjectStatus   @default(DRAFT)
  startDate    DateTime?
  endDate      DateTime?
  featured     Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  ngo          Ngo             @relation(fields: [ngoId], references: [id], onDelete: Cascade)
  milestones   Milestone[]
  donations    Donation[]
  expenses     Expense[]
}

model Milestone {
  id                  String          @id @default(cuid())
  projectId           String
  name                String
  description         String?         @db.Text
  targetDate          DateTime?
  requiredAmount      Float
  releasedAmount      Float           @default(0)
  status              MilestoneStatus @default(PENDING)
  completedAt         DateTime?
  completionNarrative String?         @db.Text
  externalVerifyLink  String?
  orderIndex          Int             @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  project             Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  evidenceFiles       EvidenceFile[]
  disbursement        Disbursement?
  outputMarkers       OutputMarker[]
}

model EvidenceFile {
  id          String   @id @default(cuid())
  milestoneId String
  url         String
  fileType    String
  fileName    String
  fileSize    Int
  hash        String?
  uploadedAt  DateTime @default(now())
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
}

model OutputMarker {
  id          String    @id @default(cuid())
  milestoneId String
  label       String
  value       String
  unit        String?
  createdAt   DateTime  @default(now())
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
}

model Donation {
  id              String        @id @default(cuid())
  userId          String
  projectId       String
  amount          Float
  currency        String        @default("USD")
  paymentMethod   PaymentMethod @default(CARD)
  stripePaymentId String?
  txHash          String?
  status          String        @default("COMPLETED")
  createdAt       DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id])
  project         Project       @relation(fields: [projectId], references: [id])
  blockchainRecord BlockchainRecord?
}

model Disbursement {
  id              String             @id @default(cuid())
  milestoneId     String             @unique
  requestedAmount Float
  approvedAmount  Float?
  status          DisbursementStatus @default(PENDING)
  approvedBy      String?
  rejectReason    String?
  txHash          String?
  processedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  milestone        Milestone          @relation(fields: [milestoneId], references: [id])
  blockchainRecord BlockchainRecord?
}

model Expense {
  id          String   @id @default(cuid())
  ngoId       String
  projectId   String?
  category    String
  amount      Float
  currency    String   @default("USD")
  description String
  receiptUrl  String?
  loggedAt    DateTime @default(now())
  ngo         Ngo      @relation(fields: [ngoId], references: [id])
  project     Project? @relation(fields: [projectId], references: [id])
}

model BlockchainRecord {
  id             String   @id @default(cuid())
  entityType     String
  donationId     String?  @unique
  disbursementId String?  @unique
  txHash         String   @unique
  blockNumber    Int?
  network        String   @default("polygon")
  timestamp      DateTime @default(now())
  donation       Donation?     @relation(fields: [donationId], references: [id])
  disbursement   Disbursement? @relation(fields: [disbursementId], references: [id])
}

model Rating {
  id        String   @id @default(cuid())
  donorId   String
  ngoId     String
  stars     Int
  comment   String?
  createdAt DateTime @default(now())
  donor     User     @relation(fields: [donorId], references: [id])
  ngo       Ngo      @relation(fields: [ngoId], references: [id])
  @@unique([donorId, ngoId])
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}
