generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  DONOR
  NGO
  ADMIN
}

enum ProjectStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  COMPLETED
  REJECTED
}

enum MilestoneStatus {
  PENDING
  UNDER_REVIEW
  COMPLETED
  REJECTED
}

enum DisbursementStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
}

enum NgoStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum PaymentMethod {
  CARD
  CRYPTO
  UPI
  BANK_TRANSFER
}

enum ProjectCategory {
  INCOME_GENERATION
  CHILD_CARE
  ELDERLY_CARE
  PHYSICALLY_DISABLED
  PET_CARE
  OTHER
}

model User {
  id                    String                @id @default(cuid())
  email                 String                @unique
  emailVerified         DateTime?
  name                  String?
  image                 String?
  role                  Role                  @default(DONOR)
  referralCode          String?               @unique @default(cuid())
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  accounts              Account[]
  sessions              Session[]
  ngo                   Ngo?
  donations             Donation[]
  ratings               Rating[]
  notifications         Notification[]
  spotlightVotes        SpotlightVote[]
  campaignsCreated      Campaign[]
  campaignContributions CampaignContributor[]
  ngoSuggestions        NgoSuggestion[]
  referralsMade         Referral[]            @relation("ReferralsMade")
  referralsReceived     Referral[]            @relation("ReferralsReceived")
}

model Ngo {
  id           String    @id @default(cuid())
  userId       String    @unique
  orgName      String
  regNumber    String?
  country      String?
  website      String?
  description  String?   @db.Text
  logoUrl      String?
  trustScore   Float     @default(0)
  status       NgoStatus @default(PENDING)
  approvedAt   DateTime?
  rejectReason String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects     Project[]
  expenses     Expense[]
  ratings      Rating[]
}

model Project {
  id                 String          @id @default(cuid())
  ngoId              String
  title              String
  description        String          @db.Text
  category           ProjectCategory
  coverImage         String?
  goalAmount         Float
  raisedAmount       Float           @default(0)
  currency           String          @default("USD")
  status             ProjectStatus   @default(DRAFT)
  startDate          DateTime?
  endDate            DateTime?
  featured           Boolean         @default(false)
  spotlightVoteCount Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  ngo                Ngo             @relation(fields: [ngoId], references: [id], onDelete: Cascade)
  milestones         Milestone[]
  donations          Donation[]
  expenses           Expense[]
  spotlightVotes     SpotlightVote[]
  campaigns          Campaign[]
}

model Milestone {
  id                  String          @id @default(cuid())
  projectId           String
  name                String
  description         String?         @db.Text
  targetDate          DateTime?
  requiredAmount      Float
  releasedAmount      Float           @default(0)
  status              MilestoneStatus @default(PENDING)
  completedAt         DateTime?
  completionNarrative String?         @db.Text
  externalVerifyLink  String?
  orderIndex          Int             @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  project             Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  evidenceFiles       EvidenceFile[]
  disbursement        Disbursement?
  outputMarkers       OutputMarker[]
}

model EvidenceFile {
  id          String    @id @default(cuid())
  milestoneId String
  url         String
  fileType    String
  fileName    String
  fileSize    Int
  hash        String?
  uploadedAt  DateTime  @default(now())
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
}

model OutputMarker {
  id          String    @id @default(cuid())
  milestoneId String
  label       String
  value       String
  unit        String?
  createdAt   DateTime  @default(now())
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
}

model Donation {
  id               String            @id @default(cuid())
  userId           String
  projectId        String
  amount           Float
  currency         String            @default("USD")
  paymentMethod    PaymentMethod     @default(CARD)
  stripePaymentId  String?
  txHash           String?
  status           String            @default("COMPLETED")
  createdAt        DateTime          @default(now())
  user             User              @relation(fields: [userId], references: [id])
  project          Project           @relation(fields: [projectId], references: [id])
  blockchainRecord BlockchainRecord?
}

model Disbursement {
  id               String             @id @default(cuid())
  milestoneId      String             @unique
  requestedAmount  Float
  approvedAmount   Float?
  status           DisbursementStatus @default(PENDING)
  approvedBy       String?
  rejectReason     String?
  txHash           String?
  processedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  milestone        Milestone          @relation(fields: [milestoneId], references: [id])
  blockchainRecord BlockchainRecord?
}

model Expense {
  id          String   @id @default(cuid())
  ngoId       String
  projectId   String?
  category    String
  amount      Float
  currency    String   @default("USD")
  description String
  receiptUrl  String?
  loggedAt    DateTime @default(now())
  ngo         Ngo      @relation(fields: [ngoId], references: [id])
  project     Project? @relation(fields: [projectId], references: [id])
}

model BlockchainRecord {
  id             String        @id @default(cuid())
  entityType     String
  donationId     String?       @unique
  disbursementId String?       @unique
  txHash         String        @unique
  blockNumber    Int?
  network        String        @default("polygon")
  timestamp      DateTime      @default(now())
  donation       Donation?     @relation(fields: [donationId], references: [id])
  disbursement   Disbursement? @relation(fields: [disbursementId], references: [id])
}

model Rating {
  id        String   @id @default(cuid())
  donorId   String
  ngoId     String
  stars     Int
  comment   String?
  createdAt DateTime @default(now())
  donor     User     @relation(fields: [donorId], references: [id])
  ngo       Ngo      @relation(fields: [ngoId], references: [id])

  @@unique([donorId, ngoId])
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// Feature 6: Notification System
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // MILESTONE_COMPLETE | CAMPAIGN_UPDATE | SPOTLIGHT_WINNER | REFERRAL_CONVERTED | NEW_PROJECT
  title     String
  message   String
  linkUrl   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Feature 7: Monthly Spotlight Vote
model SpotlightVote {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  month     Int
  year      Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  project   Project  @relation(fields: [projectId], references: [id])

  @@unique([userId, month, year])
}

// Feature 5: Group Fundraising / Campaigns
model Campaign {
  id           String                @id @default(cuid())
  creatorId    String
  projectId    String
  title        String
  description  String?               @db.Text
  goalAmount   Float
  raisedAmount Float                 @default(0)
  endsAt       DateTime?
  active       Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  creator      User                  @relation(fields: [creatorId], references: [id])
  project      Project               @relation(fields: [projectId], references: [id])
  contributors CampaignContributor[]
}

model CampaignContributor {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  amount     Float
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@unique([campaignId, userId])
}

// Feature 10: Suggest an NGO
model NgoSuggestion {
  id          String   @id @default(cuid())
  submittedBy String
  orgName     String
  website     String?
  country     String?
  reason      String   @db.Text
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [submittedBy], references: [id])
}

// Feature 11: Referral System
model Referral {
  id          String    @id @default(cuid())
  referrerId  String
  referredId  String?
  converted   Boolean   @default(false)
  convertedAt DateTime?
  createdAt   DateTime  @default(now())
  referrer    User      @relation("ReferralsMade", fields: [referrerId], references: [id])
  referred    User?     @relation("ReferralsReceived", fields: [referredId], references: [id])
}

// Feature 8: Activity Feed
model ActivityEvent {
  id           String   @id @default(cuid())
  type         String // MILESTONE_COMPLETE | DONATION | PROJECT_LAUNCH | CAMPAIGN_CREATED | SPOTLIGHT_WIN
  projectId    String?
  ngoName      String?
  projectTitle String?
  actorName    String?
  description  String
  metadata     String?  @db.Text
  createdAt    DateTime @default(now())
}
